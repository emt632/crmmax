{
  "rewrites": [
    {
      "source": "/api/cms/:path*",
      "destination": "https://data.cms.gov/provider-data/api/1/:path*"
    },
    {
      "source": "/api/legiscan/",
      "destination": "https://api.legiscan.com/"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
